 setwind(1);
_pdate="";
_pltype=6|plt1|plt3;
_plwidth=1|4|4;
 figname="fig2.tkf";
 psn= "fig2.eps";
 gstr="-c=1 -co=p -cm=.5,.5,1.5,1.5 -cf=" $+ psn;
 graphprt(gstr);
 ytics(-2.5,.5,.5,1);
 Title("Response of Inflation");
 xy(lag,z~xi~fi);
 nextwind;
 Title("Response of Unemployment");
 ytics(-1.0,1.0,.5,1);
 xy(lag,z~xu~fu);
 nextwind;
 Title("Response of Real Interest Rates");
 ytics(-2.5,3.5,1.0,1);
 xy(lag,z~xr~fr);
 nextwind;
