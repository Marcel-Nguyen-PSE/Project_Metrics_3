plt1=6*ones(cols(xu),1);
plt3=3*ones(cols(fu),1);


lag=seqa(0,1,25);
z=zeros(25,1);
library pgraph;
graphset;
 _paxht=.25;
 _ptitlht=.25;
 _pnumht=.20;
 _pdate="";
 xlabel("Lag");
 ylabel("Percent");
 begwind;
 @ window(3,3,0); @
 xsize=9/2;
 ysize=5.855/2;
 c1=0; c2=xsize; 
 r2=0; r1=ysize; 
 makewind(xsize,ysize,c1,r1,0);
 makewind(xsize,ysize,c2,r1,0);
 makewind(xsize,ysize,c1,r2,0);
 makewind(xsize,ysize,c2,r2,0); 
