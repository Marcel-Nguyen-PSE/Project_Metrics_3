_pmsgctl[.,4]=0.0*ones(rows(_pmsgctl),1);
_pmsgctl[.,5]=2*ones(rows(_pmsgctl),1);
_pmsgctl[.,6]=15*ones(rows(_pmsgctl),1);
_pmsgctl[.,7]=0*ones(rows(_pmsgctl),1);
str = "Backward Looking Taylor Rule (solid line)";
str = str $+  "\000Forward Looking  Taylor Rule (dashed line)";
_pmsgstr=str;
xlabel("");
ylabel("");
sst="Figure 2. Impulse Responses of Monetary Policy Shocks";
sst=sst $+ "\L  for Different Taylor Rule Identifying Assumptions";
title(sst);
 draw;

