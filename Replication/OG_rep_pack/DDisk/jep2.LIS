* -- Main Model: SET ORDER HERE (%%)
group(vcv=vm) mainmod $
raeq>>f_ra $
peq>>f_p $
ueq>>f_u


**************************
set impu1 1 nsteps = 0
set impp1 1 nsteps = 0
set impr1 1 nsteps = 0
set imprr1 1 nsteps = 0
set impu2 1 nsteps = 0
set impp2 1 nsteps = 0
set impr2 1 nsteps = 0
set imprr2 1 nsteps = 0

* Loop for Standard Error Bands
*
do draws=1,ndraws
(01.0032)
(01.0032)    smpl nfest nlest
(01.0055)
(01.0055)    simulate(model=mainmod) 3 * * vm
(01.0087)
(01.0087)    set u nfest nlest = f_u
(01.0133)    set p nfest nlest = f_p
(01.0179)    set ra nfest nlest = f_ra
(01.0225)
(01.0225) linreg(noprint,define=1) ra nfest nlest resra
(01.0280) # constant p{1 to nlags} u{1 to nlags} ra{1 to nlags}
(01.0433) linreg(noprint,define=2) p nfest nlest resp
(01.0488) # constant p{1 to nlags} u{1 to nlags} ra{0 to nlags}
(01.0641) linreg(noprint,define=3) u nfest nlest resu
(01.0696) # constant p{0 to nlags} u{1 to nlags} ra{0 to nlags}
(01.0849)
(01.0849) vcv(noprint,matrix=v)
(01.0866) # resra resp resu
(01.0899)
(01.0899) impulse(noprint) neqn+1 nsteps 1 V
(01.0943) # 1 impra 1 1
(01.0974) # 2 impp 1 2
(01.1005) # 3 impu 1 3
(01.1036) # 4 impr 1
(01.1061)
(01.1061) smpl 1 nsteps
(01.1080) compute std = impr(1)
(01.1102) set impp / = impp(t)/std
(01.1142) set impu / = impu(t)/std
(01.1182) set impr / = impr(t)/std
(01.1222) set imprr / = impr-impp
(01.1261)
(01.1261) set impp1 / = impp1(t)+impp(t)
(01.1306) set impu1 / = impu1(t)+impu(t)
(01.1351) set impr1 / = impr1(t)+impr(t)
(01.1396) set imprr1 / = imprr1(t)+imprr(t)
(01.1441) set impp2 / = impp2(t)+impp(t)**2
(01.1491) set impu2 / = impu2(t)+impu(t)**2
(01.1541) set impr2 / = impr2(t)+impr(t)**2
(01.1591) set imprr2 / = imprr2(t)+imprr(t)**2
(01.1641)
(01.1641)
(01.1641) end do draws
smpl 1 nsteps
set impp1 / = impp1(t)/ndraws
set impu1 / = impu1(t)/ndraws
set impr1 / = impr1(t)/ndraws
set imprr1 / = imprr1(t)/ndraws
set impp2 / = impp2(t)/ndraws
set impu2 / = impu2(t)/ndraws
set impr2 / = impr2(t)/ndraws
set imprr2 / = imprr2(t)/ndraws
set imppvar / = impp2(t)-impp1(t)**2
set impuvar / = impu2(t)-impu1(t)**2
set imprvar / = impr2(t)-impr1(t)**2
set imprrvar / = imprr2(t)-imprr1(t)**2
set imppse / = sqrt(imppvar(t))
set impuse / = sqrt(impuvar(t))
set imprse / = sqrt(imprvar(t))
set imprrse / = sqrt(imprrvar(t))


print(nodates) 1 nsteps imppse impuse imprrse imprse


