
* ----------------------------------------------- @
* -- Forward Looking Taylor Rule --
cal 1945 1 4
all 0 2000:4
open data \jepvar\ddisk\jepvar.rat
data(for=rats,compact=average) / gdpd fyff lhur
set dp / = log(gdpd(t)/gdpd(t-1))
set p / = 400*dp
set r / = fyff(t)
set u / = lhur(t)
compute fp1 = 1.5
compute fy1 = 0.5
compute olaw=-2.5
compute fu1=fy1*olaw
* -- k=4 results

compute pp=     0.47808371
compute pu=    -0.98366589
compute pr=    0.085929442

compute up=      0.047163051
compute uu=      1.4998803
compute ur=      0.070519295

compute fp2=fp1*pp+fu1*up
compute fu2=fp1*pu+fu1*uu
compute fr2=fp1*pr+fu1*ur;
compute fp=fp2/(1-fr2)
compute fu=fu2/(1-fr2)
write fp
      0.6861
write fu
     -3.4927


set ra / = r-fp*p-fu*u;

* -- VAR --
COMPUTE  NEQN   = 3                                               ;*<<<<<<
COMPUTE  nlags = 4                                               ;*<<<<<<
COMPUTE  NSTEPS = 25
compute nfest = 1960:1
compute nlest = 2000:4
compute ndraws = 500
seed 807687

** Set Up identities
** Set Up identities
equation(identity) 4 r
# ra p u
associate 4
# 1 fp fu


linreg(noprint,define=1,frml=raeq) ra nfest nlest resra
# constant p{1 to nlags} u{1 to nlags} ra{1 to nlags}
linreg(noprint,define=2,frml=peq) p nfest nlest resp
# constant p{1 to nlags} u{1 to nlags} ra{0 to nlags}
linreg(noprint,define=3,frml=ueq) u nfest nlest resu
# constant p{0 to nlags} u{1 to nlags} ra{0 to nlags}

vcv(noprint,matrix=v)
# resra resp resu

vcv(noprint,matrix=vm)
# resra resp resu

impulse(noprint) neqn+1 nsteps 1 V
# 1 impra 1 1
# 2 impp 1 2
# 3 impu 1 3
# 4 impr 1

smpl 1 nsteps
compute std = impr(1)
set impp / = impp(t)/std
set impu / = impu(t)/std
set impr / = impr(t)/std
set imprr / = impr-impp
print(nodates) 1 nsteps impp impu imprr impr


