cal 1945 1 12
all 2010:12
dedit(new) jepvar.rat
sou FYFF.rtd
include FYFF yy nfirst nlast 1
   INTEREST RATE: FEDERAL FUNDS (EFFECTIVE) (% PER ANNUM,NSA)

sou LHUR.rtd
include LHUR yy nfirst nlast 1
   UNEMPLOYMENT RATE: ALL WORKERS, 16 YEARS & OVER (%,SA)

save
end 1
cal 1945 1 4
all 2010:4

sou GDPD.rtd
include GDPD yy nfirst nlast 1
   GROSS DOMESTIC PRODUCT:IMPLICIT PRICE DEFLATOR(INDEX,92=100)(T7.1)

save
end 1
cal 1945 1 1
all 2010:1
save
quit
end
