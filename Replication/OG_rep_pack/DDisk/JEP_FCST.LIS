cal 1945 1 4
all 0 2000:4
compute nph = 2
open data \jepvar\ddisk\jepvar.rat
data(for=rats,compact=average) / gdpd fyff lhur
set dp / = log(gdpd(t)/gdpd(t-1))
set p / = 400*dp
set r / = fyff(t)
set u / = lhur(t)
set pact = log(gdpd(t)/gdpd(t-nph))
set pact = (400/nph)*pact
compute nfest = 1960:1
compute nlest = 2000:4
compute nffcst = 1985:1
compute nlfcst = 2000:4


* -- Forecast series
clear uar
clear par
clear rar
clear uvar
clear pvar
clear rvar
clear tmp
clear tmpp
clear tmpr
clear tmpu
*
* -- Fixed Lags
*
compute lag=4

do regind = nffcst, nlfcst
(01.0036)
(01.0036) * -- Univariate Inflation
(01.0036)   linreg(noprint,define=1) p nfest regind
(01.0081)   # constant p{1 to lag}
(01.0140)   forecast(noprint) 1 nph
(01.0161)   # 1 tmp
(01.0180)   compute ptmp=0.0
(01.0194)   do np=1,nph
(02.0226)    compute ptmp=ptmp+tmp(regind+np)
(02.0264)   end do np
(01.0266)   compute par(regind)=ptmp/nph
(01.0301)
(01.0301)   linreg(noprint,define=1) u nfest regind
(01.0346)   # constant u{1 to lag}
(01.0405)   forecast(noprint) 1 nph
(01.0426)   # 1 tmp
(01.0445)   compute uar(regind)=tmp(regind+nph)
(01.0479)
(01.0479)   linreg(noprint,define=1) r nfest regind
(01.0524)   # constant r{1 to lag}
(01.0583)   forecast(noprint) 1 nph
(01.0604)   # 1 tmp
(01.0623)   compute rar(regind)=tmp(regind+nph)
(01.0657)
(01.0657) * VAR
(01.0657) *
(01.0657) *
(01.0657)  system 1 to 3
(01.0690)   variables p u r
(01.0726)   lags 1 to lag
(01.0757)   det constant
(01.0770)  end(system)
(01.0773)  estimate(noftests,noprint,outsigma=vm) nfest regind
(01.0811)  forecast(noprint) 3 nph
(01.0832)   # 1 tmpp
(01.0851)   # 2 tmpu
(01.0870)   # 3 tmpr
(01.0889)   compute rvar(regind)=tmpr(regind+nph)
(01.0923)   compute uvar(regind)=tmpu(regind+nph)
(01.0957)   compute ptmp=0.0
(01.0971)   do np=1,nph
(02.1003)    compute ptmp=ptmp+tmpp(regind+np)
(02.1041)   end do np
(01.1043)   compute pvar(regind)=ptmp/nph
(01.1078) end do
*
* -- Compute Forecast Errors
*
set epar / = par(t)-pact(t+nph)
set euar / = uar(t)-u(t+nph)
set erar / = rar(t)-r(t+nph)
set epvar / = pvar(t)-pact(t+nph)
set euvar / = uvar(t)-u(t+nph)
set ervar / = rvar(t)-r(t+nph)
set epar / = epar(t)**2
set euar / = euar(t)**2
set erar / = erar(t)**2
set epvar / = epvar(t)**2
set euvar / = euvar(t)**2
set ervar / = ervar(t)**2
statistics(noprint) epar /; compute cpar = sqrt(%mean)
statistics(noprint) euar /; compute cuar = sqrt(%mean)
statistics(noprint) erar /; compute crar = sqrt(%mean)
statistics(noprint) epvar /; compute cpvar = sqrt(%mean)
statistics(noprint) euvar /; compute cuvar = sqrt(%mean)
statistics(noprint) ervar /; compute crvar = sqrt(%mean)
write 'par' cpar
par
      0.6951
write 'uar' cuar
uar
      0.2798
write 'rar' crar
rar
      0.7685
write 'pvar' cpvar
pvar
      0.6787
write 'uvar' cuvar
uvar
      0.2900
write 'rvar' crvar
rvar
      0.6797
