sedp=sedp[.,2:4];
seu=seu[.,2:4];
ser=ser[.,2:4];

edp=edp[.,2:4];
eu=eu[.,2:4];
er=er[.,2:4];

edp1=edp+sedp; 
edp2=edp-sedp;
eu1=eu+seu; eu2=eu-seu;
er1=er+ser; er2=er-ser;




lag=seqa(0,1,25);
z=zeros(25,1);
library pgraph;
graphset;
_pdate="";
_pltype=6|6|3|3;
_plwidth=1|3|1|1;
 figname="fig1.tkf";
 psn= "fig1.eps";
 gstr="-c=1 -co=p -cm=.5,.5,1.5,1.5 -cf=" $+ psn;
 graphprt(gstr);
 _paxht=.25;
 _ptitlht=.25;
 _pnumht=.20;
 _pdate="";
 xlabel("Lag");
 ylabel("Percent");
 begwind;
 @ window(3,3,0); @
 xsize=9/3;
 ysize=5.855/3;
 c1=0; c2=xsize; c3=2*xsize;
 r3=0; r2=ysize; r1=2*ysize;
 makewind(xsize,ysize,c1,r1,0);
 makewind(xsize,ysize,c2,r1,0);
 makewind(xsize,ysize,c3,r1,0);
 makewind(xsize,ysize,c1,r2,0);
 makewind(xsize,ysize,c2,r2,0); 
 makewind(xsize,ysize,c3,r2,0);
 makewind(xsize,ysize,c1,r3,0); 
 makewind(xsize,ysize,c2,r3,0);
 makewind(xsize,ysize,c3,r3,0);
 makewind(9,6.855,0,0,1);
 setwind(1);
title("Inflation Shock to Inflation");
ytics(0.0,1.25,.25,1);
xy(lag,z~edp[.,1]~edp1[.,1]~edp2[.,1]);
nextwind;
title("Inflation Shock to Unemployment");
ytics(-0.1,0.3,.1,1);
xy(lag,z~edp[.,2]~edp1[.,2]~edp2[.,2]);
nextwind;
title("Inflation Shock to Interest Rate");
ytics(0.0,0.75,.25,1);
xy(lag,z~edp[.,3]~edp1[.,3]~edp2[.,3]);
nextwind;
title("Unemployment Shock to Inflation");
ytics(-2.0,1.0,.5,1);
xy(lag,z~eu[.,1]~eu1[.,1]~eu2[.,1]);
nextwind;
title("Unemployment Shock to Unemployment");
ytics(-1.0,2.0,.5,1);
xy(lag,z~eu[.,2]~eu1[.,2]~eu2[.,2]);
nextwind;
title("Unemployment Shock to Interest Rate");
ytics(-5.0,1.0,1.0,1); 
xy(lag,z~eu[.,3]~eu1[.,3]~eu2[.,3]);
nextwind;
title("Interest Rate Shock to Inflation");
ytics(-0.5,0.5,.25,1);
xy(lag,z~er[.,1]~er1[.,1]~er2[.,1]);
nextwind;
title("Interest Rate Shock to Unemployment");
ytics(-0.2,0.3,.1,1);
xy(lag,z~er[.,2]~er1[.,2]~er2[.,2]);
nextwind;
title("Interest Rate Shock to Interest Rate");
ytics(-0.5,1.5,.5,1);
xy(lag,z~er[.,3]~er1[.,3]~er2[.,3]);
nextwind;
_ptitlht=.15;
_paxes=0;
xlabel("");
ylabel("");
sst="Figure 1. Impulse Responses in the";
sst=sst $+ "\L  Inflation-Unemployement-Interest Rate Recursive VAR";
title(sst);
 draw;

endwind;
