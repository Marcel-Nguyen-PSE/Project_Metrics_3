cal 1945 1 4
all 0 2000:4
open data \jepvar\ddisk\jepvar.rat
data(for=rats,compact=average) / gdpd fyff lhur
set dp / = log(gdpd(t)/gdpd(t-1))
set p / = 400*dp
set r / = fyff(t)
set u / = lhur(t)

* -- VAR --
COMPUTE  NEQN   = 3
COMPUTE  nlags = 4
COMPUTE  NSTEPS = 25
compute nfest = 1960:1
compute nlest = 2000:4
compute ndraws = 500
seed 807687

system(model=var1) 1 to 3
variables p u r
lags 1 to nlags
det constant
end(system)
estimate(print,OUTSIGMA=V1) nfest nlest

