* -- Main Model: SET ORDER HERE (%%)
group(vcv=vm) mainmod $
peq>>f_p $
ueq>>f_u $
req>>f_r


**************************
set impp_u1 1 nsteps = 0
set impp_p1 1 nsteps = 0
set impp_r1 1 nsteps = 0
set impp_u2 1 nsteps = 0
set impp_p2 1 nsteps = 0
set impp_r2 1 nsteps = 0

set impu_u1 1 nsteps = 0
set impu_p1 1 nsteps = 0
set impu_r1 1 nsteps = 0
set impu_u2 1 nsteps = 0
set impu_p2 1 nsteps = 0
set impu_r2 1 nsteps = 0

set impr_u1 1 nsteps = 0
set impr_p1 1 nsteps = 0
set impr_r1 1 nsteps = 0
set impr_u2 1 nsteps = 0
set impr_p2 1 nsteps = 0
set impr_r2 1 nsteps = 0

* Loop for Standard Error Bands
*
do draws=1,ndraws
(01.0032)
(01.0032)    smpl nfest nlest
(01.0055)
(01.0055)    simulate(model=mainmod) 3 * * vm
(01.0087)
(01.0087)    set u nfest nlest = f_u
(01.0133)    set p nfest nlest = f_p
(01.0179)    set r nfest nlest = f_r
(01.0225)
(01.0225) linreg(noprint,define=1) p nfest nlest resp
(01.0280) # constant p{1 to nlags} u{1 to nlags} r{1 to nlags}
(01.0433) linreg(noprint,define=2) u nfest nlest resu
(01.0488) # constant p{0 to nlags} u{1 to nlags} r{1 to nlags}
(01.0641) linreg(noprint,define=3) r nfest nlest resr
(01.0696) # constant p{0 to nlags} u{0 to nlags} r{1 to nlags}
(01.0849) vcv(noprint,matrix=v) nfest nlest
(01.0886) # resp resu resr
(01.0919)
(01.0919) impulse(noprint) neqn nsteps 1 v
(01.0960) # 1 impp_p 1 *
(01.0986) # 2 impp_u 1 *
(01.1012) # 3 impp_r 1 *
(01.1038) compute scl = impp_p(1)
(01.1060) set impp_p 1 nsteps = impp_p(t)/scl
(01.1114) set impp_u 1 nsteps = impp_u(t)/scl
(01.1168) set impp_r 1 nsteps = impp_r(t)/scl
(01.1222)
(01.1222) impulse(noprint) neqn nsteps 2 v
(01.1263) # 1 impu_p 1 *
(01.1289) # 2 impu_u 1 *
(01.1315) # 3 impu_r 1 *
(01.1341) compute scl = impu_u(1)
(01.1363) set impu_p 1 nsteps = impu_p(t)/scl
(01.1417) set impu_u 1 nsteps = impu_u(t)/scl
(01.1471) set impu_r 1 nsteps = impu_r(t)/scl
(01.1525)
(01.1525) impulse(noprint) neqn nsteps 3 v
(01.1566) # 1 impr_p 1 *
(01.1592) # 2 impr_u 1 *
(01.1618) # 3 impr_r 1 *
(01.1644) compute scl = impr_r(1)
(01.1666) set impr_p 1 nsteps = impr_p(t)/scl
(01.1720) set impr_u 1 nsteps = impr_u(t)/scl
(01.1774) set impr_r 1 nsteps = impr_r(t)/scl
(01.1828)
