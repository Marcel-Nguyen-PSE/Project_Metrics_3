cal 1945 1 4
all 0 2000:4
open data \jepvar\ddisk\jepvar.rat
data(for=rats,compact=average) / gdpd fyff lhur
set dp / = log(gdpd(t)/gdpd(t-1))
set p / = 400*dp
set r / = fyff(t)
set u / = lhur(t)

smpl 1955:1 2000:4
open copy pur.asc
copy(format=free, org=obs) / p u r
close copy

end

